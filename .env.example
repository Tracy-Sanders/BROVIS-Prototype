# BROVIS — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001

# ── Dev-only API key fallbacks ───────────────────────────────────────────────
# These are used ONLY when running BROVIS locally without a browser session
# (e.g. automated tests, curl). In production the keys come from the user's
# browser via the BYOK (Bring Your Own Key) CONFIG form and are never stored
# on the server.
OPENWEATHER_API_KEY=     # https://openweathermap.org/api  (free tier works)
NEWSAPI_KEY=             # https://newsapi.org             (free tier works)
CLAUDE_API_KEY=          # https://console.anthropic.com

# ── Google Calendar OAuth2 ───────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services →
# Credentials → OAuth 2.0 Client IDs. Set redirect URI to:
#   http://localhost:<PORT>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
