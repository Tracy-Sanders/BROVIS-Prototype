views:
  - type: table
    name: Table
    order:
      - file.name
      - file.path
    sort:
      - property: file.name
        direction: ASC
  - type: map
    name: Globe
    order:
      - file.name
      - location
    defaultZoom: 1
    markerIcon: note.icon
    markerColor: note.color
    coordinates: note.location
